# --- Global Configuration ---
# The base path where all application data will be stored
STORAGE_ROOT=/storage/appdata

# The base path for shared media (music, movies, etc.)
MEDIA_ROOT=/storage/media

# Your system timezone
TZ=America/Denver

# The User ID and Group ID the containers should run as
# You can find these by running the `id` command in your terminal
PUID=1000
PGID=1000

# --- App Specific Variables (Optional/Default) ---
# Some apps may require additional variables here or in their local .env files.
# See individual apps/*/.env.example files for details.
